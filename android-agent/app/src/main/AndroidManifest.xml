<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

    <!--
        Permissions: minimum required for full Android Enterprise Device Owner
        management. Device-owner-required permissions (e.g. WIPE_DATA on the
        DPM API) do NOT need declaring; they're granted by virtue of being
        Device Owner.
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA"
                     tools:ignore="ManifestTypo" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"
                     tools:ignore="ManifestTypo" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" tools:ignore="QueryAllPackagesPermission" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- Special access: enables foreground-app tracking (SIEM-style activity log).
         Granted manually in Settings → Apps → Special access → Usage data access.
         The agent's ActivityMonitor surfaces an `activity.permission.needed` event
         when this is missing so the admin UI can prompt for it. -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
                     tools:ignore="ProtectedPermissions" />

    <application
        android:name=".MDMApplication"
        android:label="@string/app_name"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.MDM"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- DeviceAdminReceiver — declared in :mdm-core but visible here via merge -->
        <receiver
            android:name="com.mdm.core.admin.MDMDeviceAdminReceiver"
            android:label="@string/app_name"
            android:description="@string/device_admin_description"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
                <action android:name="android.app.action.PROFILE_PROVISIONING_COMPLETE" />
                <action android:name="android.app.action.DEVICE_OWNER_CHANGED" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!--
            Foreground service that keeps the MQTT command channel alive.
            Declares camera + location + microphone types so the service can
            host the CAPTURE_PHOTO / GET_LOCATION / START_AUDIO_STREAM commands
            while running.
        -->
        <service
            android:name="com.mdm.command.CommandService"
            android:exported="false"
            android:foregroundServiceType="dataSync|camera|location|microphone" />

        <!--
            Receives PackageInstaller session commit callbacks. In DA mode the
            session returns STATUS_PENDING_USER_ACTION which carries an Intent
            the receiver launches so the system "Install this app?" dialog
            appears on the phone.
        -->
        <receiver
            android:name="com.mdm.command.InstallResultReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.mdm.PACKAGE_INSTALL_RESULT" />
            </intent-filter>
        </receiver>

        <!--
            Doze-resistant keep-alive. setAndAllowWhileIdle on this receiver
            (every ~3 min) re-spawns CommandService even when the OS has
            killed it for memory pressure, App Standby, or battery
            optimization. Self-rescheduling — each tick arms the next.
        -->
        <receiver
            android:name="com.mdm.command.KeepAliveAlarm$Receiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.mdm.KEEPALIVE_PING" />
            </intent-filter>
        </receiver>

        <!-- WorkManager init handled by Hilt -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            tools:node="remove" />
    </application>
</manifest>
