<?xml version="1.0" encoding="utf-8"?>
<!-- Disable all auto-backup. MDM agents must never be restored to a different
     device than the one they were enrolled on. -->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
