# Copy this file to .env and adjust before running docker compose.
#
#   cd server && cp .env.example .env && docker compose up -d
#
# Anything marked "MUST replace" needs a fresh value before production.

ENV=development
LOG_LEVEL=info

# ---- Postgres -------------------------------------------------------------
# Username is hard-coded to `mdm` in docker-compose; only the password is
# configurable here.
POSTGRES_PASSWORD=mdm

# ---- JWT signing ----------------------------------------------------------
# MUST replace in production. Use at least 32 random bytes:
#   openssl rand -base64 48
# Every service that issues/verifies JWTs reads this from the env.
JWT_SECRET=replace-me-with-a-real-32-byte-random-key

# ---- MQTT broker (Mosquitto) ---------------------------------------------
# Agent uses these credentials to subscribe to its per-device command topic.
MQTT_USER=mdm
MQTT_PASS=mdmpass

# ---- MinIO / object storage ----------------------------------------------
# Used for APK uploads, device photo captures, log bundles. MUST replace in
# production — minioadmin/minioadmin is a known-public credential pair.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Fallback public host the presigner uses when the inbound HTTP request has no
# X-Forwarded-Host (rare; mostly direct curl). The admin nginx normally
# overrides this per-request, so a remote browser sees URLs that resolve on
# its own network without any static reconfiguration.
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# ---- Public base URL ------------------------------------------------------
# Goes into QR enrollment payloads and the APK download link served back to
# new phones. Must be reachable from the device's network.
PUBLIC_BASE_URL=https://mdm.example.com
